# Copy to `.env` and fill in what you need. `.env` is gitignored.
# Every value is optional — unset features simply no-op or fall back.

# --- Progress notifications (scripts/run_benchmark.sh via notify.py) ---
# Mattermost and Slack incoming webhooks accept the same {"text": ...} JSON
# payload, so either works out of the box — just paste the webhook URL here.
# (Discord/Teams use a different key; see notify.py to adapt the payload.)
# If unset, the sweep runs identically with notifications silently disabled.
MATTERMOST_WEBHOOK_URL=

# --- Common Voice Danish test set (scripts/fetch_common_voice_da.py) ---
# Needed only to download the CV tarball. Get a key at
# https://datacollective.mozillafoundation.org/  (skip it if you pass --tarball).
MOZILLA_API_KEY=

# --- Hugging Face ---
# Token for pushing results / pulling private models. Anonymous read works for
# public datasets and models, so this is only needed for writes or gated repos.
HF_TOKEN=

# --- Runtime paths (export at run time; shown here for reference) ---
# Where fetch_common_voice_da.py wrote the local CV manifest:
# CV_DATA_DIR=./cv_da
